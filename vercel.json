{
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/:path*",
        "has": [
          {
            "type": "host",
            "value": "cv.clementberger.fr"
          }
        ],
        "destination": "/cv.pdf"
      },
      {
        "source": "/:path*",
        "has": [
          {
            "type": "host",
            "value": "transfert.clementberger.fr"
          }
        ],
        "destination": "/transfert/:path*"
      }
    ]
  }
}