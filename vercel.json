{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "cv.clementberger.fr"
        }
      ],
      "destination": "/cv.pdf"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "transfert.clementberger.fr"
        }
      ],
      "destination": "/transfert/index.html"
    }
  ]
}