{
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/:path*",
        "has": [
          {
            "type": "host",
            "value": "cv.clementberger.fr"
          }
        ],
        "destination": "/public/cv.pdf"
      },
      {
        "source": "/",
        "has": [
          {
            "type": "host",
            "value": "transfert.clementberger.fr"
          }
        ],
        "destination": "/public/transfert/index.html"
      },
      {
        "source": "/:path+",
        "has": [
          {
            "type": "host",
            "value": "transfert.clementberger.fr"
          }
        ],
        "destination": "/public/transfert/:path+"
      }
    ]
  }
}